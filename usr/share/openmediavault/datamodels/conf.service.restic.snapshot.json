{
  "type": "config",
  "id": "conf.service.restic.snapshot",
  "title": "Restic backup job",
  "queryinfo": {
    "xpath": "//services/restic/snapshots/snapshot",
    "iterable": true,
    "idproperty": "uuid"
  },
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuidv4"
    },
    "enable": {
      "type": "boolean",
      "default": true
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "hash": {
      "type": "string",
      "default": ""
    },
    "tags": {
      "type": "string",
      "default": ""
    },
    "csvsharedfolderrefs": {
      "type": "string",
      "default": ""
    },
    "reporef": {
      "type": "string",
      "format": "uuidv4"
    },
    "exclude": {
      "type": "string",
      "default": ""
    },
    "execution": {
      "type": "string",
      "enum": ["exactly", "hourly", "daily", "weekly", "monthly", "yearly", "reboot"],
      "default": "daily"
    },
    "minute": {
      "type": "string",
      "default": "0"
    },
    "everynminute": {
      "type": "boolean",
      "default": false
    },
    "hour": {
      "type": "string",
      "default": "0"
    },
    "everynhour": {
      "type": "boolean",
      "default": false
    },
    "dayofmonth": {
      "type": "string",
      "default": "*"
    },
    "everyndayofmonth": {
      "type": "boolean",
      "default": false
    },
    "month": {
      "type": "string",
      "default": "*"
    },
    "dayofweek": {
      "type": "string",
      "default": "*"
    },
    "keeplast": {
      "type": "integer",
      "default": 0
    },
    "keepdaily": {
      "type": "integer",
      "default": 7
    },
    "keepweekly": {
      "type": "integer",
      "default": 4
    },
    "keepmonthly": {
      "type": "integer",
      "default": 12
    },
    "keepyearly": {
      "type": "integer",
      "default": 0
    }
  }
}
