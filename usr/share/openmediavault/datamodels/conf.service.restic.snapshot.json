{
  "type": "config",
  "id": "conf.service.restic.snapshot",
  "title": "Restic backup job",
  "queryinfo": {
    "xpath": "//services/restic/snapshots/snapshot",
    "iterable": true,
    "idproperty": "uuid"
  },
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuidv4"
    },
    "enable": {
      "type": "boolean",
      "default": true
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "hash": {
      "type": "string",
      "default": ""
    },
    "tags": {
      "type": "string",
      "default": ""
    },
    "csvsharedfolderrefs": {
      "type": "string",
      "default": ""
    },
    "reporef": {
      "type": "string",
      "format": "uuidv4"
    },
    "exclude": {
      "type": "string",
      "default": ""
    },
    "scheduleminute": {
      "type": "string",
      "default": "0"
    },
    "schedulehour": {
      "type": "string",
      "default": "0"
    },
    "scheduledayofmonth": {
      "type": "string",
      "default": "*"
    },
    "schedulemonth": {
      "type": "string",
      "default": "*"
    },
    "scheduledayofweek": {
      "type": "string",
      "default": "*"
    },
    "keeplast": {
      "type": "integer",
      "default": 0
    },
    "keepdaily": {
      "type": "integer",
      "default": 7
    },
    "keepweekly": {
      "type": "integer",
      "default": 4
    },
    "keepmonthly": {
      "type": "integer",
      "default": 12
    },
    "keepyearly": {
      "type": "integer",
      "default": 0
    }
  }
}
