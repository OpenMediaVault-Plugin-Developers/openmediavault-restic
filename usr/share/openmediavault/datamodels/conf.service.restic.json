{
  "type": "config",
  "id": "conf.service.restic",
  "title": "Restic",
  "queryinfo": {
    "xpath": "//services/restic",
    "iterable": false
  },
  "properties": {
    "settings": {
      "type": "object",
      "properties": {
        "cachedir": {
          "type": "string",
          "default": "/var/cache/restic"
        }
      }
    },
    "repos": {
      "type": "object",
      "properties": {
        "repo": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "format": "uuidv4"
              },
              "name": {
                "type": "string"
              },
              "passphrase": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "local",
                  "s3",
                  "sftp",
                  "b2",
                  "rest"
                ],
                "default": "local"
              },
              "sharedfolderref": {
                "type": "string",
                "default": ""
              },
              "uri": {
                "type": "string",
                "default": ""
              },
              "accesskey": {
                "type": "string",
                "default": ""
              },
              "secretkey": {
                "type": "string",
                "default": ""
              }
            }
          }
        }
      }
    },
    "snapshots": {
      "type": "object",
      "properties": {
        "snapshot": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "format": "uuidv4"
              },
              "enable": {
                "type": "boolean",
                "default": true
              },
              "name": {
                "type": "string",
                "default": ""
              },
              "hash": {
                "type": "string",
                "default": ""
              },
              "tags": {
                "type": "string",
                "default": ""
              },
              "csvsharedfolderrefs": {
                "type": "string",
                "default": ""
              },
              "reporef": {
                "type": "string",
                "format": "uuidv4"
              },
              "exclude": {
                "type": "string",
                "default": ""
              },
              "execution": {
                "type": "string",
                "default": "daily"
              },
              "minute": {
                "type": "string",
                "default": "0"
              },
              "everynminute": {
                "type": "boolean",
                "default": false
              },
              "hour": {
                "type": "string",
                "default": "0"
              },
              "everynhour": {
                "type": "boolean",
                "default": false
              },
              "dayofmonth": {
                "type": "string",
                "default": "*"
              },
              "everyndayofmonth": {
                "type": "boolean",
                "default": false
              },
              "month": {
                "type": "string",
                "default": "*"
              },
              "dayofweek": {
                "type": "string",
                "default": "*"
              },
              "keeplast": {
                "type": "integer",
                "default": 0
              },
              "keepdaily": {
                "type": "integer",
                "default": 7
              },
              "keepweekly": {
                "type": "integer",
                "default": 4
              },
              "keepmonthly": {
                "type": "integer",
                "default": 12
              },
              "keepyearly": {
                "type": "integer",
                "default": 0
              }
            }
          }
        }
      }
    },
    "envvars": {
      "type": "object",
      "properties": {
        "envvar": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "format": "uuidv4"
              },
              "envname": {
                "type": "string"
              },
              "envvalue": {
                "type": "string"
              },
              "reporef": {
                "type": "string",
                "oneOf": [
                  {
                    "type": "string",
                    "format": "uuidv4"
                  },
                  {
                    "type": "string",
                    "enum": [
                      "shared"
                    ]
                  },
                  {
                    "type": "string",
                    "maxLength": 0
                  }
                ],
                "default": ""
              }
            }
          }
        }
      }
    }
  }
}
