{
  "type": "config",
  "id": "conf.service.restic.restoretest",
  "title": "Restic restore test job",
  "queryinfo": {
    "xpath": "//services/restic/restoretests/restoretest",
    "iterable": true,
    "idproperty": "uuid"
  },
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuidv4"
    },
    "enable": {
      "type": "boolean",
      "default": true
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "reporef": {
      "type": "string",
      "format": "uuidv4"
    },
    "mode": {
      "type": "string",
      "enum": ["dryrun", "verify"],
      "default": "dryrun"
    },
    "targetref": {
      "type": "string",
      "default": ""
    },
    "cleanup": {
      "type": "boolean",
      "default": true
    },
    "includepath": {
      "type": "string",
      "default": ""
    },
    "execution": {
      "type": "string",
      "enum": ["exactly", "hourly", "daily", "weekly", "monthly", "yearly", "reboot"],
      "default": "weekly"
    },
    "minute": {
      "type": "string",
      "default": "0"
    },
    "everynminute": {
      "type": "boolean",
      "default": false
    },
    "hour": {
      "type": "string",
      "default": "0"
    },
    "everynhour": {
      "type": "boolean",
      "default": false
    },
    "dayofmonth": {
      "type": "string",
      "default": "*"
    },
    "everyndayofmonth": {
      "type": "boolean",
      "default": false
    },
    "month": {
      "type": "string",
      "default": "*"
    },
    "dayofweek": {
      "type": "string",
      "default": "*"
    },
    "sendemail": {
      "type": "boolean",
      "default": false
    },
    "emailonerror": {
      "type": "boolean",
      "default": false
    }
  }
}
