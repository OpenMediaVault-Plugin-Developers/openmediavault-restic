#!/bin/bash
{{ pillar['headers']['auto_generated'] }}
{{ pillar['headers']['warning'] }}
# Restic restore test job: {{ job.uuid }}{% if job.name %} ({{ job.name }}){% endif %}
{# POSIX single-quote shell escaping: wrap in single quotes and replace any
   embedded single quote with the '\'' sequence. Keeps secrets and paths safe
   from word splitting and shell injection. #}
{% macro sq(val) -%}
'{{ val | string | replace("'", "'\\''") }}'
{%- endmacro %}
LOG_DIR="/var/log/restic"
LOG_FILE="${LOG_DIR}/restic.log"
JOB_ID="{{ job.uuid }}"

mkdir -p "${LOG_DIR}"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [${JOB_ID}] $*" | tee -a "${LOG_FILE}"
}

{% if job.sendemail | string | lower not in ['false', '0', 'no', 'off', ''] %}
# Capture this run's output so it can be emailed to root once the test finishes.
# Output still reaches the log file via the `tee -a` calls throughout the
# script; redirecting stdout/stderr here just collects a copy for the email.
EMAIL_MODE="{% if job.emailonerror | string | lower not in ['false', '0', 'no', 'off', ''] %}onerror{% else %}always{% endif %}"
EMAIL_SUBJECT={{ sq('restic restore test' ~ ((': ' ~ job.name) if job.name else '')) }}
EMAIL_TMP="$(mktemp)"
_send_email() {
    local rc="$1"
    if [ -f "${EMAIL_TMP}" ]; then
        if [ "${EMAIL_MODE}" = "always" ] || { [ "${EMAIL_MODE}" = "onerror" ] && [ "${rc}" -ne 0 ]; }; then
            mail -E -s "${EMAIL_SUBJECT}" -a "From: Cron Daemon <root>" root < "${EMAIL_TMP}" || true
        fi
        rm -f "${EMAIL_TMP}"
    fi
}
trap '_send_email $?' EXIT
exec >"${EMAIL_TMP}" 2>&1
{% endif %}

log "=== Starting restore test{% if job.name %}: {{ job.name }}{% endif %} ({{ job.mode }}) ==="

# Load shared environment variables
if [ -f /etc/restic/restic-envvar-shared ]; then
    set -a
    source /etc/restic/restic-envvar-shared
    set +a
fi

# Load repository-specific environment variables
if [ -f /etc/restic/restic-envvar-{{ job.reporef }} ]; then
    set -a
    source /etc/restic/restic-envvar-{{ job.reporef }}
    set +a
fi

# Set repository credentials and cache
export RESTIC_PASSWORD={{ sq(repo.passphrase) }}
{% if cachedir %}
export RESTIC_CACHE_DIR={{ sq(cachedir) }}
{% endif %}

{% if repo.type == 'local' %}
export RESTIC_REPOSITORY={{ sq(repo_path) }}
{% elif repo.type == 's3' %}
export RESTIC_REPOSITORY={{ sq('s3:' ~ repo.uri) }}
export AWS_ACCESS_KEY_ID={{ sq(repo.accesskey) }}
export AWS_SECRET_ACCESS_KEY={{ sq(repo.secretkey) }}
{% elif repo.type == 'b2' %}
export RESTIC_REPOSITORY={{ sq('b2:' ~ repo.uri) }}
export B2_ACCOUNT_ID={{ sq(repo.accesskey) }}
export B2_ACCOUNT_KEY={{ sq(repo.secretkey) }}
{% elif repo.type == 'sftp' %}
export RESTIC_REPOSITORY={{ sq('sftp:' ~ repo.uri) }}
{% elif repo.type == 'rest' %}
export RESTIC_REPOSITORY={{ sq('rest:' ~ repo.uri) }}
{% elif repo.type == 'rclone' %}
export RESTIC_REPOSITORY={{ sq('rclone:' ~ repo.uri) }}
{% endif %}

# Build the restore command as an array so paths/patterns with spaces or shell
# metacharacters are passed to restic verbatim.
RESTORE_ARGS=(--retry-lock 5m)

{% set is_verify = job.mode == 'verify' %}
{% if is_verify %}
# Verify mode: full restore that checksums each restored file's contents.
RESTORE_ARGS+=(--verify)
TARGET={{ sq(target_path) }}
{% else %}
# Dry-run mode: preview only. restic writes nothing but still requires a
# --target, so we point at a path that is never created.
RESTORE_ARGS+=(--dry-run --verbose=2)
TARGET='/var/lib/openmediavault-restic/dryrun'
{% endif %}

{% if job.includepath %}
RESTORE_ARGS+=(--include {{ sq(job.includepath) }})
{% endif %}

log "Running: restic restore latest ${RESTORE_ARGS[*]} --target ${TARGET}"
/usr/bin/restic restore latest "${RESTORE_ARGS[@]}" --target "${TARGET}" 2>&1 | tee -a "${LOG_FILE}"
RESTORE_EXIT=${PIPESTATUS[0]}

{% if is_verify and job.cleanup | string | lower not in ['false', '0', 'no', 'off', ''] %}
# Clean up restored data. We only ever remove the per-test subdirectory that
# was created for this job, never the surrounding shared folder. Runs even on
# failure so partial restores do not accumulate.
if [ -n "${TARGET}" ]; then
    log "Cleaning up restored data at ${TARGET}"
    rm -rf "${TARGET}"
fi
{% endif %}

if [ ${RESTORE_EXIT} -ne 0 ]; then
    log "ERROR: Restore test failed with exit code ${RESTORE_EXIT}"
    exit ${RESTORE_EXIT}
fi

log "=== Restore test completed successfully ==="
